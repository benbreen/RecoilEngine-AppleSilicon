From 262a308f55620dcf87bb66f7787490a15dad960e Mon Sep 17 00:00:00 2001
From: benbreen <8338320+benbreen@users.noreply.github.com>
Date: Fri, 10 Jul 2026 22:25:40 +0100
Subject: [PATCH 3/4] zink: ZINK_NO_TRIANGLE_FANS knob to force zink-side fan
 lowering

Zink passes triangle fans through when the Vulkan implementation reports
portability-subset triangleFans support. On implementations whose fan
support is itself emulated with a GPU prepass (KosmicKrisp unrolls fan
indices in a compute dispatch on a second queue), zink's own lowering (a
cheap CPU index rewrite) is the better path. ZINK_NO_TRIANGLE_FANS=1
pretends the capability is absent so the lowering kicks in.

Off by default; no behavior change unset. Candidate for an upstream MR.
---
 src/gallium/drivers/zink/zink_screen.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/src/gallium/drivers/zink/zink_screen.c b/src/gallium/drivers/zink/zink_screen.c
index 7aea90f9..76052af9 100644
--- a/src/gallium/drivers/zink/zink_screen.c
+++ b/src/gallium/drivers/zink/zink_screen.c
@@ -3623,6 +3623,12 @@ zink_internal_create_screen(const struct pipe_screen_config *config, int64_t dev
       screen->have_triangle_fans = (VK_TRUE == screen->info.portability_subset_feats.triangleFans);
    }
 #endif // VK_KHR_PORTABILITY_SUBSET_EXTENSION_NAME
+   /* ZINK_NO_TRIANGLE_FANS=1: pretend the implementation lacks triangle
+    * fans so zink lowers them itself (cheap CPU index rewrite). On drivers
+    * whose native fan support is a GPU prepass (e.g. KosmicKrisp's compute
+    * unroll on a second queue), zink's lowering is the cheaper path. */
+   if (debug_get_bool_option("ZINK_NO_TRIANGLE_FANS", false))
+      screen->have_triangle_fans = false;
 
    check_base_requirements(screen);
    util_live_shader_cache_init(&screen->shaders, zink_create_gfx_shader_state, zink_delete_shader_state);
